  "item": [
    {
      "name": "whatsapp-bff (:5153)",
      "description": "Channel BFF: receives WhatsApp Cloud API webhooks, forwards inbound messages to conversation-orchestrator via Kafka, and exposes an internal endpoint the orchestrator calls to send replies back through the WhatsApp Cloud API.",
      "item": [
        {
          "name": "Webhook verification (GET)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{whatsapp_bff_url}}/webhooks/whatsapp?hub.mode=subscribe&hub.verify_token={{whatsapp_verify_token}}&hub.challenge=challenge-123",
              "host": ["{{whatsapp_bff_url}}"],
              "path": ["webhooks", "whatsapp"],
              "query": [
                { "key": "hub.mode", "value": "subscribe" },
                { "key": "hub.verify_token", "value": "{{whatsapp_verify_token}}" },
                { "key": "hub.challenge", "value": "challenge-123" }
              ]
            },
            "description": "Meta's webhook handshake. Returns 200 with the raw challenge string echoed back when hub.verify_token matches WhatsApp:VerifyToken; 403 otherwise."
          }
        },
        {
          "name": "Webhook - inbound text message (POST)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// WhatsApp signs every webhook delivery with HMAC-SHA256 over the raw body,",
                  "// keyed by WhatsApp:AppSecret. whatsapp-bff rejects the request with 401 if",
                  "// X-Hub-Signature-256 doesn't match, so compute it here before sending.",
                  "const secret = pm.collectionVariables.get('whatsapp_app_secret');",
                  "const body = pm.request.body.raw;",
                  "const hash = CryptoJS.HmacSHA256(body, secret).toString(CryptoJS.enc.Hex);",
                  "pm.request.headers.upsert({ key: 'X-Hub-Signature-256', value: 'sha256=' + hash });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"object\": \"whatsapp_business_account\",\n  \"entry\": [\n    {\n      \"id\": \"215589313241560883\",\n      \"changes\": [\n        {\n          \"value\": {\n            \"messaging_product\": \"whatsapp\",\n            \"metadata\": {\n              \"display_phone_number\": \"15551797781\",\n              \"phone_number_id\": \"7794189252778687\"\n            },\n            \"contacts\": [\n              {\n                \"profile\": { \"name\": \"Jessica Laverdetman\" },\n                \"wa_id\": \"13557825698\"\n              }\n            ],\n            \"messages\": [\n              {\n                \"from\": \"17863559966\",\n                \"id\": \"wamid.TEST_TEXT_MESSAGE\",\n                \"timestamp\": \"1758254144\",\n                \"text\": { \"body\": \"Quero renegociar minha divida\" },\n                \"type\": \"text\"\n              }\n            ]\n          },\n          \"field\": \"messages\"\n        }\n      ]\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{whatsapp_bff_url}}/webhooks/whatsapp",
              "host": ["{{whatsapp_bff_url}}"],
              "path": ["webhooks", "whatsapp"]
            },
            "description": "Real WhatsApp Cloud API delivery shape. Persisted to Kafka (channel.webhook.received) and, once consumed, forwarded to conversation-orchestrator's POST /messages. Returns 200 as soon as it's durably queued - it does not wait for downstream processing."
          }
        },
        {
          "name": "Send outbound message (POST /internal/messages)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"To\": \"17863559966\",\n  \"Type\": \"text\",\n  \"Text\": \"Ola! Vamos falar sobre a renegociacao da sua divida.\"\n}"
            },
            "url": {
              "raw": "{{whatsapp_bff_url}}/internal/messages",
              "host": ["{{whatsapp_bff_url}}"],
              "path": ["internal", "messages"]
            },
            "description": "Internal endpoint conversation-orchestrator's ChannelReplyClient calls to relay an agent reply to the customer. Forwards to the real WhatsApp Cloud API - without a valid WhatsApp:AccessToken/PhoneNumberId this returns 502 (upstream rejected the send), which is expected until real credentials are configured."
          }
        }
      ]
    },
    {
      "name": "conversation-orchestrator (:5268)",
      "description": "Owns conversation/session state, calls agent-runtime-renegotiation for a decision, and routes the outcome to a channel reply, a human handoff, or both, plus audit/event publishing.",
      "item": [
        {
          "name": "Ingest inbound text message (POST /messages)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"MessageId\": \"wamid.TEST_TEXT_MESSAGE\",\n  \"From\": \"17863559966\",\n  \"ConversationId\": \"{{sample_conversation_id}}\",\n  \"Type\": 0,\n  \"Text\": \"Quero renegociar minha divida\",\n  \"Interactive\": null,\n  \"RawPayload\": null,\n  \"ReceivedAt\": \"2026-07-07T12:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{orchestrator_url}}/messages",
              "host": ["{{orchestrator_url}}"],
              "path": ["messages"]
            },
            "description": "Type is the ChannelMessageType enum as a plain integer: 0=Text, 1=Interactive, 2=Unsupported (matches whatsapp-bff's own serialization). Returns 202 Accepted immediately; the actual agent-runtime call, reply, and handoff/audit calls happen inside the request but their outcomes are only visible in logs, not in this response body."
            }
        },
        {
          "name": "Ingest inbound interactive reply (POST /messages)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"MessageId\": \"wamid.TEST_INTERACTIVE_REPLY\",\n  \"From\": \"17863559966\",\n  \"ConversationId\": \"{{sample_conversation_id}}\",\n  \"Type\": 1,\n  \"Text\": null,\n  \"Interactive\": { \"Id\": \"option_renegociar\", \"Title\": \"Quero renegociar\" },\n  \"RawPayload\": null,\n  \"ReceivedAt\": \"2026-07-07T12:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{orchestrator_url}}/messages",
              "host": ["{{orchestrator_url}}"],
              "path": ["messages"]
            }
          }
        }
      ]
    },
    {
      "name": "agent-runtime-renegotiation (:8100, Python)",
      "description": "Runs the Bedrock/Strands agent (or the keyword-based mock when MOCK_AGENT_ENABLED=true) and returns a structured AgentDecision. Wire contract is PascalCase to match .NET's default JSON serialization.",
      "item": [
        {
          "name": "Process - renegotiation request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ConversationId\": \"{{sample_conversation_id}}\",\n  \"MessageType\": \"Text\",\n  \"Text\": \"Quero renegociar minha divida\",\n  \"JourneyStage\": \"initial\",\n  \"LastIntent\": null\n}"
            },
            "url": {
              "raw": "{{agent_runtime_url}}/process",
              "host": ["{{agent_runtime_url}}"],
              "path": ["process"]
            },
            "description": "In mock mode (app/agent/mock.py), text containing \"renegoc\" returns intent=renegotiation_request with RequiresHandoff=false."
          }
        },
        {
          "name": "Process - debt inquiry",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ConversationId\": \"{{sample_conversation_id}}\",\n  \"MessageType\": \"Text\",\n  \"Text\": \"Quanto eu devo de boleto atrasado?\",\n  \"JourneyStage\": \"initial\",\n  \"LastIntent\": null\n}"
            },
            "url": {
              "raw": "{{agent_runtime_url}}/process",
              "host": ["{{agent_runtime_url}}"],
              "path": ["process"]
            },
            "description": "In mock mode, debt/boleto/parcela keywords return intent=debt_inquiry."
          }
        },
        {
          "name": "Process - human handoff request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ConversationId\": \"{{sample_conversation_id}}\",\n  \"MessageType\": \"Text\",\n  \"Text\": \"Quero falar com um atendente humano\",\n  \"JourneyStage\": \"initial\",\n  \"LastIntent\": null\n}"
            },
            "url": {
              "raw": "{{agent_runtime_url}}/process",
              "host": ["{{agent_runtime_url}}"],
              "path": ["process"]
            },
            "description": "In mock mode, atendente/humano keywords force RequiresHandoff=true, HandoffReason=customer_requested_human."
          }
        },
        {
          "name": "Process - unmatched text (greeting fallback)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ConversationId\": \"{{sample_conversation_id}}\",\n  \"MessageType\": \"Text\",\n  \"Text\": \"Oi, bom dia\",\n  \"JourneyStage\": null,\n  \"LastIntent\": null\n}"
            },
            "url": {
              "raw": "{{agent_runtime_url}}/process",
              "host": ["{{agent_runtime_url}}"],
              "path": ["process"]
            }
          }
        },
        {
          "name": "Swagger / OpenAPI docs (GET)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{agent_runtime_url}}/docs",
              "host": ["{{agent_runtime_url}}"],
              "path": ["docs"]
            },
            "description": "Sanity check that the service is up."
          }
        }
      ]
    },
