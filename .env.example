# Copy to .env (same folder as docker-compose.yml) and fill in real values.
# .env is gitignored; this file documents what docker-compose.yml reads.

# --- Internal auth / multitenancy (all P1-hardened services) ---
# docker-compose.override.yml fails Compose interpolation immediately if this is unset.
# Generate a local secret without versioning it:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
INTERNAL_AUTH_SIGNING_KEY=
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# --- WhatsApp Cloud API (whatsapp-bff) ---
# Required to actually send/receive real WhatsApp messages. AppSecret/VerifyToken already
# have local-dev defaults in docker-compose.yml, so the webhook works without these for
# local testing with synthetic payloads.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=local-dev-app-secret
WHATSAPP_VERIFY_TOKEN=local-dev-verify-token

# --- OpenAI (agent-runtime-renegotiation) ---
# MOCK_AGENT_ENABLED defaults to true in docker-compose.yml, so /process returns a canned
# decision (app/agent/mock.py) instead of calling OpenAI - no API key needed for an
# end-to-end test of the pipeline. Set it to false here once you fill in a real key
# below and want the agent to actually call the LLM.
MOCK_AGENT_ENABLED=true
OPENAI_MODEL_ID=gpt-4o-mini
OPENAI_API_KEY=

# --- Overrides, only needed if you stand these services up elsewhere ---
# docker-compose.yml's own defaults already point at the real containers in this workspace
# (knowledge-service, conversation-handoff-service, conversation-audit-service) - these two
# variables only matter if you want to point at a different deployment instead.
KNOWLEDGE_SERVICE_BASE_URL=http://knowledge-service:8500
HANDOFF_SERVICE_BASE_URL=http://conversation-handoff-service:8080
